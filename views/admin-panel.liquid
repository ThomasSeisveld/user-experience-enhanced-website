{% render 'partials/head.liquid', title: title, menuClass: menuClass %}
<main>
  <header class="admin-header">
    <h1>Instrument Management Panel</h1>
    <p class="panel-subtitle">Scan QR-codes of kies een instrument om hem te beheren</p>
    <ul class="nav-list">
      <li class="{% if action == 'qr-code' %}active{% endif %}">
        {% comment %} <a href="/admin">qr-code</a> {% endcomment %}
      </li>
      <li class="{% if action == 'handmatig' %}active{% endif %}">
        {% comment %} <a href="/admin">Handmatig</a> {% endcomment %}
      </li>
      <li class="{% if action == 'overzicht' %}active{% endif %}">
        {% comment %} <a href="/admin">Overzicht</a> {% endcomment %}
      </li>
    </ul>
  </header>

  <section class="admin-content">
    {% comment %}
      <article class="scanner-entry">
        <h2>QR-code Scanner</h2>
      </article>

      <article class="overzicht-entry">
        <h2>kies uit overzicht</h2>
      </article>
    {% endcomment %}

    <article class="manual-entry" id="manual-entry">
      {% if selectedInstrument %}
      <section class="selected-instrument">
        <p class="selected-instrument__label">Geselecteerd instrument</p>
        <figure class="selected-instrument__figure">
          {% if selectedInstrument.photo %}
            <img
              src="https://fdnd-agency.directus.app/assets/{{ selectedInstrument.photo }}"
              alt="{{ selectedInstrument.name }}"
              class="selected-instrument__image"
            >
          {% endif %}

          <figcaption class="selected-instrument__caption">
            <h3 class="selected-instrument__name">
              {{ selectedInstrument.name | default: selectedInstrument.instrument }}
            </h3>
            <span class="status status-{{ selectedInstrument.status | downcase | replace: ' ', '-' | default: 'onbekend' }}">
              {{ selectedInstrument.status | default: 'onbekend' }}
            </span>
          </figcaption>
        </figure>
      </section>
      {% else %}
        <legend>Selecteer een instrument:</legend>
      {% endif %}

      <form action="/admin/update-instrument" method="POST" class="admin-update-form">
        <fieldset class="form-group">
          <input
            id="instrument-key"
            name="key"
            type="search"
            list="instrument-keys"
            placeholder="zoek je instrument op key"
            autocomplete="off"
            {% if selectedInstrument %}
              value="{{ selectedInstrument.key }}"
            {% endif %}
            required
          >
          <datalist id="instrument-keys">
            {% for instrument in instruments %}
              <option
                value="{{ instrument.key }}"
                label="{{ instrument.name | default: instrument.instrument }}"
              ></option>
            {% endfor %}
          </datalist>
        </fieldset>
        <fieldset class="form-group">
          <legend>Status aanpassen</legend>

          <label for="status-select">Nieuwe status</label>
          <select id="status-select" name="status" required>
            <option value="">Selecteer een status</option>
            {% for status in statusOptions %}
              <option
                value="{{ status }}"
                {% if selectedInstrument and selectedInstrument.status == status %}
                  selected
                {% endif %}
              >
                {{ status }}
              </option>
            {% endfor %}
          </select>
        </fieldset>

        <button type="submit" class="btn btn-primary">Status bijwerken</button>
      </form>
    </article>
    <output id="manual-result" class="result-message" style="display: none;"></output>
    {% comment %}
      <section class="recent-actions">
        <h2>Recente Acties</h2>
        <article id="actions-log" class="actions-log">
          <p class="empty-log">Nog geen acties uitgevoerd</p>
        </article>
      </section>
    {% endcomment %}

    <footer class="admin-footer">
      <a href="/" class="btn btn-secondary">Terug naar home</a>
    </footer>
  </section>
</main>
<script>
      const inputElement = document.getElementById('instrument-key');

      inputElement.addEventListener('change', () => {
        const key = inputElement.value;
        if (key) {
          window.location.href = `/admin/panel?instrument=${encodeURIComponent(key)}`;
        }
      });
</script>
{% render 'partials/foot.liquid' %}
